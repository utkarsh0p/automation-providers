# Copy to .env and fill in. The backend holds ALL provider config; the frontend
# receives only per-request embed sessions.

FRONTEND_ORIGIN=http://localhost:5173

# --- Zapier (MVP) --------------------------------------------------------
# "Powered by Zapier" Workflow Element. Requires a PUBLISHED PUBLIC Zapier
# integration; copy the client id from Developer Platform -> Embed -> Settings
# -> Credentials. This is a PUBLIC value, not a secret.
ZAPIER_CLIENT_ID=
# Copy the exact element tag + script URL from the live "Generate Code" output at
# zapier.com/partner/embed. The tag is mid-rename (zapier-full-experience vs
# zapier-workflow) and the script URL must come from Zapier — do not guess it.
ZAPIER_ELEMENT_TAG=zapier-full-experience
ZAPIER_SCRIPT_URL=

# --- Activepieces (MVP) --------------------------------------------------
# Self-hosted Activepieces. See ACTIVEPIECES_SETUP.md.
ACTIVEPIECES_URL=http://localhost:8080
# Embed mode:
#   iframe = license-free, frames the instance directly (use this to test now)
#   sdk    = per-user auto-login JWT (needs an Activepieces Enterprise license)
ACTIVEPIECES_EMBED_MODE=iframe
# Only needed when ACTIVEPIECES_EMBED_MODE=sdk (Platform Settings -> Signing Keys;
# AP does not store the private key, so copy it when generated). \n escapes are fine.
ACTIVEPIECES_SIGNING_KEY_ID=
ACTIVEPIECES_PRIVATE_KEY=
ACTIVEPIECES_PROJECT_ID=agentegration

# --- n8n (deferred) ------------------------------------------------------
N8N_EMBED_URL=
