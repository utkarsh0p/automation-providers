# Copy to .env in this dir on the VPS and fill in. Never commit the real .env.

# Two subdomains, both A records pointing at the VPS IP (147.93.169.144). No protocol.
API_DOMAIN=api.vorldx.cember.in
AP_DOMAIN=ap.vorldx.cember.in

# The exact origin of your Vercel frontend (for CORS). Include https://, no trailing slash.
FRONTEND_ORIGIN=https://vorldx.cember.in

# Strong, unique secrets. Generate with:
#   AP_ENCRYPTION_KEY:    openssl rand -hex 16   (exactly 32 hex chars)
#   AP_JWT_SECRET:        openssl rand -hex 32
#   AP_POSTGRES_PASSWORD: openssl rand -hex 24
AP_ENCRYPTION_KEY=
AP_JWT_SECRET=
AP_POSTGRES_PASSWORD=
