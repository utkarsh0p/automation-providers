# Copy to .env on the VPS (in deploy/activepieces/) and fill in. Never commit the real .env.

# Public domain whose DNS A record points at this VPS's IP. No protocol, no slash.
AP_DOMAIN=ap.yourdomain.com

# Strong, unique secrets — DO NOT reuse the local dev values. Generate with:
#   AP_ENCRYPTION_KEY:    openssl rand -hex 16   (exactly 32 hex chars)
#   AP_JWT_SECRET:        openssl rand -hex 32
#   AP_POSTGRES_PASSWORD: openssl rand -hex 24
AP_ENCRYPTION_KEY=
AP_JWT_SECRET=
AP_POSTGRES_PASSWORD=
